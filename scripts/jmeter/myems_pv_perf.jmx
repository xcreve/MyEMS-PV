        <hashTree/>
        <kg.apc.jmeter.vizualizers.ResponseTimesPercentiles guiclass="kg.apc.jmeter.vizualizers.ResponseTimesPercentilesGui" testclass="kg.apc.jmeter.vizualizers.ResponseTimesPercentiles" testname="jp@gc - Response Times Percentiles" enabled="true">
          <boolProp name="ResultCollector.error_logging">false</boolProp>
